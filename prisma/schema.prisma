generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  ADMIN
  EDITOR
  JOURNALIST
  CONTRIBUTOR
  READER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum AdvertisementPlacement {
  HOME_TOP
  HOME_SIDEBAR
  ARTICLE_INLINE
  ARTICLE_SIDEBAR
  CATEGORY_TOP
  SPONSORED_BLOCK
}

enum CommentStatus {
  PENDING
  APPROVED
  REPORTED
  DELETED
}

enum FeaturedSectionType {
  HERO
  SECONDARY
  LATEST
  OPINION
  MULTIMEDIA
  TRENDING
}

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  status        UserStatus     @default(ACTIVE)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  authorProfile AuthorProfile?
  articles      Article[]
  comments      Comment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([roleId])
  @@index([status])
  @@index([createdAt])
}

model AuthorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  bio         String?  @db.Text
  title       String?
  location    String?
  website     String?
  xUrl        String?
  facebookUrl String?
  instagramUrl String?
  seoTitle    String?
  seoDescription String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  description    String?   @db.Text
  color          String?
  isActive       Boolean   @default(true)
  seoTitle       String?
  seoDescription String?
  ogImage        String?
  articles       Article[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive])
  @@index([name])
}

model Tag {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  description    String?      @db.Text
  seoTitle       String?
  seoDescription String?
  articles       ArticleTag[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([name])
}

model Article {
  id             String             @id @default(cuid())
  title          String
  subtitle       String?
  slug           String             @unique
  summary        String?            @db.Text
  contentHtml    String             @db.Text
  contentJson    Json?
  status         ArticleStatus      @default(DRAFT)
  readingMinutes Int                @default(1)
  viewsCount     Int                @default(0)
  isFeatured     Boolean            @default(false)
  publishedAt    DateTime?
  scheduledAt    DateTime?
  archivedAt     DateTime?
  authorId       String
  author         User               @relation(fields: [authorId], references: [id])
  categoryId     String
  category       Category           @relation(fields: [categoryId], references: [id])
  coverImageId   String?
  coverImage     MediaAsset?        @relation("ArticleCoverImage", fields: [coverImageId], references: [id])
  videoUrl       String?
  audioUrl       String?
  seoTitle       String?
  seoDescription String?
  keywords       String[]
  ogImage        String?
  canonicalUrl   String?
  tags           ArticleTag[]
  mediaAssets    ArticleMediaAsset[]
  comments       Comment[]
  views          ArticleView[]
  featuredItems  FeaturedArticle[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([scheduledAt])
  @@index([categoryId, status])
  @@index([authorId, status])
  @@index([viewsCount])
  @@index([isFeatured])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([articleId, tagId])
  @@index([tagId])
}

model MediaAsset {
  id              String              @id @default(cuid())
  type            MediaType
  provider        String
  url             String
  secureUrl       String?
  publicId        String?
  altText         String?
  caption         String?
  credit          String?
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  durationSeconds Int?
  articles        ArticleMediaAsset[]
  coverFor        Article[]           @relation("ArticleCoverImage")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([type])
  @@index([provider])
  @@index([createdAt])
}

model ArticleMediaAsset {
  articleId    String
  mediaAssetId String
  sortOrder    Int      @default(0)
  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([articleId, mediaAssetId])
  @@index([mediaAssetId])
  @@index([sortOrder])
}

model Advertisement {
  id          String                 @id @default(cuid())
  name        String
  placement   AdvertisementPlacement
  imageUrl    String?
  targetUrl   String?
  html        String?                @db.Text
  sponsorName String?
  isActive    Boolean                @default(false)
  startsAt    DateTime?
  endsAt      DateTime?
  impressions Int                    @default(0)
  clicks      Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([placement, isActive])
  @@index([startsAt, endsAt])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  consent     Boolean  @default(false)
  isActive    Boolean  @default(true)
  source      String?
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model Comment {
  id        String        @id @default(cuid())
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String?
  authorEmail String?
  content   String        @db.Text
  status    CommentStatus @default(PENDING)
  reportedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([articleId, status])
  @@index([userId])
  @@index([createdAt])
}

model ArticleView {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  ipHash    String?
  userAgent String?
  referrer  String?
  country   String?
  createdAt DateTime @default(now())

  @@index([articleId, createdAt])
  @@index([createdAt])
}

model SiteSettings {
  id             String   @id @default(cuid())
  siteName       String   @default("Mezkla2")
  siteUrl        String?
  description    String?  @db.Text
  logoUrl        String?
  defaultOgImage String?
  contactEmail   String?
  facebookUrl    String?
  xUrl           String?
  instagramUrl   String?
  youtubeUrl     String?
  adsEnabled     Boolean  @default(true)
  commentsEnabled Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FeaturedSection {
  id          String              @id @default(cuid())
  name        String
  type        FeaturedSectionType
  slug        String              @unique
  isActive    Boolean             @default(true)
  sortOrder   Int                 @default(0)
  articles    FeaturedArticle[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([type, isActive])
  @@index([sortOrder])
}

model FeaturedArticle {
  sectionId String
  articleId String
  sortOrder Int      @default(0)
  section   FeaturedSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  article   Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([sectionId, articleId])
  @@index([articleId])
  @@index([sortOrder])
}
